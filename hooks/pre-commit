#!/usr/bin/env bash
# Raven Pre-Commit Hook (standalone script)
# Install: raven install-hook
# Or manually: cp hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo "🔒 Raven Pre-Commit Security Scan"
echo "=================================="

# Check if raven is installed
if ! command -v raven &> /dev/null; then
    echo -e "${YELLOW}⚠️  Raven not found in PATH${NC}"
    echo "   Install: go install github.com/raven-security/raven@latest"
    exit 0
fi

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(go|js|ts|jsx|tsx|py|java|php|c|cpp|cs|rs|rb|kt|swift|dart|ex|exs|scala|lua|sol|sh|bash|tf|tfvars|yaml|yml|json|dockerfile)$' || true)

if [ -z "$STAGED_FILES" ]; then
    echo -e "${GREEN}✓ No relevant files staged${NC}"
    exit 0
fi

echo "📁 Scanning $(echo "$STAGED_FILES" | wc -l) staged file(s)..."
echo ""

# Run raven on staged files
SCAN_RESULT=0
SCAN_OUTPUT=$(echo "$STAGED_FILES" | xargs raven scan --format json 2>&1) || SCAN_RESULT=$?

# Check for critical issues
if echo "$SCAN_OUTPUT" | grep -q '"severity":\s*"critical"'; then
    echo -e "${RED}🚨 CRITICAL security issues found!${NC}"
    echo ""
    echo "$SCAN_OUTPUT" | grep -o '"message":\s*"[^"]*"' | head -5 | sed 's/"message": "//;s/"$//'
    echo ""
    echo -e "${RED}Commit blocked. Options:${NC}"
    echo "  1. Fix the issues"
    echo "  2. Add #raven-ignore annotations for safe code"
    echo "  3. git commit --no-verify  # Skip hook (not recommended)"
    exit 1
fi

# Check for secrets (zero tolerance)
if echo "$SCAN_OUTPUT" | grep -q '"category":\s*"secrets"'; then
    echo -e "${RED}🚨 SECRETS DETECTED in staged files!${NC}"
    echo ""
    echo "Remove secrets and use:"
    echo "  - Environment variables (process.env.VAR)"
    echo "  - Secret manager (AWS Secrets Manager, Vault, etc.)"
    echo "  - .env files (never commit!)"
    exit 1
fi

# Check for high severity
if echo "$SCAN_OUTPUT" | grep -q '"severity":\s*"high"'; then
    if [ "${RAVEN_BLOCK_ON_HIGH:-false}" = "true" ]; then
        echo -e "${RED}⚠️  HIGH severity issues found (RAVEN_BLOCK_ON_HIGH=true)${NC}"
        exit 1
    fi
    echo -e "${YELLOW}⚡ HIGH severity issues found (review recommended)${NC}"
fi

echo -e "${GREEN}✓ Pre-commit security scan passed${NC}"
exit 0
